{
  "name": "arizona-wine-experience",
  "version": "1.0.0",
  "description": "Static website for Arizona wine experiences",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "test": "node --test",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run test && npm run test:e2e && npm run format:check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{html,js,css,md}\"",
    "format:check": "prettier --check \"**/*.{html,js,css,md}\""
  },
  "keywords": [
    "wine",
    "arizona",
    "static-site"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1"
  }
}
